# Supabase — copy this file to `.env` and fill in your project's values.
# Project Settings → API in the Supabase dashboard.
#
# The anon key is PUBLIC (safe to ship in the browser). Data is protected by
# Row Level Security. NEVER put the service_role key in this file or any
# frontend/VITE_ variable — it bypasses RLS.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
