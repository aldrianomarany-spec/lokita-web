# Supabase — copy this file to `.env` and fill in your project's values.
# Project Settings → API in the Supabase dashboard.
#
# The anon key is PUBLIC (safe to ship in the browser). Data is protected by
# Row Level Security. NEVER put the service_role key in this file or any
# frontend/VITE_ variable — it bypasses RLS.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Public URL the app is served from — used so password-reset / OAuth links
# point at the real site instead of localhost. Leave blank for local dev
# (falls back to the current origin). In Vercel set it to your live URL,
# e.g. https://lokita-web.vercel.app  — and whitelist that URL in
# Supabase → Auth → URL Configuration (Site URL + Redirect URLs).
VITE_SITE_URL=

# PROTOTYPE payments: a public image URL of the owner's fixed QRIS code.
# When set, checkout shows this QR and the buyer confirms payment manually
# (the seller must verify money arrived — the app can't). Leave blank to use
# the real Midtrans flow via /api/qris/* (see SETUP-PAYMENTS.md).
VITE_QRIS_IMAGE_URL=
