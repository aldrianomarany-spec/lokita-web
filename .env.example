# Supabase — copy this file to `.env` and fill in your project's values.
# Project Settings → API in the Supabase dashboard.
#
# The anon key is PUBLIC (safe to ship in the browser). Data is protected by
# Row Level Security. NEVER put the service_role key in this file or any
# frontend/VITE_ variable — it bypasses RLS.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Public URL the app is served from — used so password-reset / OAuth links
# point at the real site instead of localhost. Leave blank for local dev
# (falls back to the current origin). In Vercel set it to your live URL,
# e.g. https://lokita-web.vercel.app  — and whitelist that URL in
# Supabase → Auth → URL Configuration (Site URL + Redirect URLs).
VITE_SITE_URL=

# ---- Payments (three modes, no code changes to switch) ----
# Default (both blank): PROTOTYPE — checkout generates a scannable demo QR per
# order (encodes order + amount; no real money) and the buyer confirms manually.
#
# VITE_QRIS_IMAGE_URL: public image URL of the owner's fixed QRIS code. When
# set, checkout shows this QR instead; buyer still confirms manually (the
# seller must verify money arrived — the app can't).
VITE_QRIS_IMAGE_URL=
# VITE_PAYMENT_MODE=midtrans: real Midtrans charges via /api/qris/* with
# automatic webhook confirmation (see SETUP-PAYMENTS.md for the server keys).
VITE_PAYMENT_MODE=
